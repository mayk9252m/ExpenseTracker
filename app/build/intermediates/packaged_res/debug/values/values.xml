    <string name="add_transaction">Add Transaction</string>
    <string name="app_name">MK Wallet</string>
    <string name="budget_alert_50">You have used 50%% of your monthly budget</string>
    <string name="budget_alert_75">Warning! You have used 75%% of your monthly budget</string>
    <string name="budget_exceeded">Budget exceeded!</string>
