    <dimen name="card_elevation">2dp</dimen>
    <dimen name="item_spacing">8dp</dimen>
    <dimen name="screen_padding">16dp</dimen>
    <dimen name="text_body">14sp</dimen>
    <dimen name="text_caption">12sp</dimen>
